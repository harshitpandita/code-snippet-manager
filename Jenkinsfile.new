pipeline {
  agent any

  stages {
    stage('Install & Test') {
      steps {
        dir('backend') {
          sh 'npm ci'
          sh 'npm test'
        }
      }
    }

    stage('Build & Deploy (Docker Compose)') {
      steps {
        sh 'docker compose down || true'
        sh 'docker compose up --build -d'
      }
    }
  }

  post {
    failure {
      echo 'Build failed. Check the console output for errors.'
    }
  }
}
